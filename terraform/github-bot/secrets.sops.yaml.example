# Copy to secrets.sops.yaml, fill in, then encrypt:
#   sops -e -i secrets.sops.yaml
#
# Format: YAML (the file extension `.sops.yaml` requires it). The Taskfile reads
# this with `sops -d --output-type dotenv` and exports each top-level key/value
# as an env var before running terraform — so `GITHUB_TOKEN: ghp_xxx` here
# becomes `GITHUB_TOKEN=ghp_xxx` in the env.
#
# Same convention as the authentik module.

# Classic GitHub PAT — needs `repo` scope for personal repos. Generate at
# https://github.com/settings/tokens (classic, with `repo` checked).
GITHUB_TOKEN: REPLACE_ME

# Garage S3 backend creds (same Garage instance as authentik module).
AWS_ACCESS_KEY_ID: REPLACE_ME
AWS_SECRET_ACCESS_KEY: REPLACE_ME

# Garage compatibility: recent AWS SDK versions enforce checksums by default,
# which Garage doesn't support. WHEN_REQUIRED falls back to the old behavior.
AWS_REQUEST_CHECKSUM_CALCULATION: WHEN_REQUIRED
AWS_RESPONSE_CHECKSUM_VALIDATION: WHEN_REQUIRED
