# Copy to secrets.sops.yaml in this same directory, fill in, then encrypt:
#   sops -e -i secrets.sops.yaml
#
# Environment-level credentials shared by every leaf. The Taskfile loads this
# with `sops -d --output-type dotenv` and exports each top-level key as an env
# var before invoking terragrunt. Per-leaf item values live in each leaf's own
# op-secrets.sops.yaml — keep those there.

# Domain used by root.hcl to derive the S3 endpoint and (optionally) URLs.
TF_VAR_domain: my_domain.com

# 1Password Service Account token. Create at:
#   https://my.1password.com/developer-tools/infrastructure-secrets/serviceaccount
# Grant write access to every vault referenced across leaves.
OP_SERVICE_ACCOUNT_TOKEN: ops_replace_me

# Garage S3 backend creds (same Garage instance as the other modules).
AWS_ACCESS_KEY_ID: REPLACE_ME
AWS_SECRET_ACCESS_KEY: REPLACE_ME

# Garage compatibility: recent AWS SDK versions enforce checksums by default,
# which Garage doesn't support. WHEN_REQUIRED falls back to the old behavior.
AWS_REQUEST_CHECKSUM_CALCULATION: WHEN_REQUIRED
AWS_RESPONSE_CHECKSUM_VALIDATION: WHEN_REQUIRED
